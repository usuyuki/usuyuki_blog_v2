    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tryghost/content-api": "^1.12.6",
    "@tryghost/helpers": "^1.1.103",
    "astro": "^6.1.9",
    "emoji-picker-element": "^1.29.1",
    "emoji-picker-element-data": "^1.8.0",
    "image-size": "^2.0.2",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
