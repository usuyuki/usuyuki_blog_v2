{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "1": "pnpm format && pnpm lint && pnpm check && pnpm test:run && pnpm build",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "prisma generate && node scripts/build-emoji-data.mjs && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tryghost/content-api": "^1.12.9",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/node": "11.0.0-alpha.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/svelte": "9.0.0-alpha.2",
    "@biomejs/biome": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/jsdom": "^28.0.3",
    "@types/tryghost__content-api": "^1.3.17",
    "@vitest/ui": "^4.1.8",
    "astro": "7.0.0-beta.3",
    "emoji-picker-element": "^1.29.1",
    "emoji-picker-element-data": "^1.8.0",
    "postcss-html": "^1.8.1",
    "prisma": "^7.8.0",
    "svelte": "^5.56.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@prisma/client",
      "sharp"
    ],
    "patchedDependencies": {
      "@astrojs/node@11.0.0-alpha.0": "patches/@astrojs__node@11.0.0-alpha.0.patch"
    }
  }
}
