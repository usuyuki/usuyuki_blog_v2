---
import "~/styles/blog/ghostContent.css";
import "~/styles/blog/wordpressContent.css";
import "~/styles/blog/ghostToc.css";
import "~/styles/blog/blogCommon.css";
import YMDMolecule from "~/components/atom/date/YMDMolecule.astro";
import TOC from "~/components/atom/TOC.astro";
import TagList from "~/components/atom/tag/TagList.astro";
import EmojiReaction from "~/components/organism/article/EmojiReaction.svelte";
import ArticleLayout from "~/layouts/extends/ArticleLayout.astro";
import { ghostApiWithRetry } from "~/libs/ghostClient";
import { generateTOC } from "~/libs/helper/generateTOC";
import { iso8601TimeToDate } from "~/libs/helper/iso8601TimeToDate";
import { judgeWpArticle } from "~/libs/helper/judgeWpArticle";
import { optimizeGhostImageUrl } from "~/libs/helper/optimizeGhostImages";
import astroLogger from "~/libs/astroLogger";
import { LOG_TYPES } from "~/libs/logTypes";
import type { TOCType } from "~/types/TOCType";
import { createProxyImageUrl } from "~/libs/imageProxy";
import { isSlug } from "~/libs/validation/isSlug";

const slug = Astro.params.slug;
if (!isSlug(slug)) {
	astroLogger.warn("Invalid slug parameter", {
		logType: LOG_TYPES.ACCESS,
		slug: slug,
		slugType: typeof slug,
		route: Astro.url.pathname,
	});
	return new Response(null, { status: 404 });
}

const post = await ghostApiWithRetry.posts.read(
	{
		slug: slug,
		include: "tags",
	},
	3,
	Astro.request,
);

if (!post) {
	astroLogger.warn("Post not found", {
		logType: LOG_TYPES.ACCESS,
		slug,
		route: `/${slug}`,
	});
	return new Response(null, { status: 404 });
}
const publishedDate = iso8601TimeToDate(post.published_at || "");

astroLogger.requestLog(Astro.request, { status: 200 });

const headMeta = {
	title: post.title || "",
	slug: post.slug,
	// excerptの名に反して指定しないと全部出てくるので、改行して150字で切る。
	description: (post.excerpt || "").replace(/\r?\n/g, "").slice(0, 150),
	ogImage: createProxyImageUrl(post.feature_image || ""),
};

const tocList: TOCType[] = generateTOC(post.html || "");
const isWpArticle = judgeWpArticle(post.html || "");
---

<ArticleLayout {...headMeta}>
	<div class="flex justify-end mx-auto w-full lg:w-4/5 xl:w-5/7 flex-wrap">
		<div class="w-full pb-4 flex justify-center">
			{
				post.feature_image ? (
					<img
						src={optimizeGhostImageUrl(post.feature_image, { width: 600, height: 600 })}
						width={600}
						height={600}
						class="object-cover w-96 h-96 rounded-md"
						alt="記事サムネイル"
						transition:name={'image-' + post.slug}
						loading="eager"
						fetchpriority="high"
					/>
				) : (
					''
				)
			}
		</div>
		<div class="md:w-1/5 hidden md:block">
			<YMDMolecule
				year={publishedDate.year}
				month={publishedDate.month}
				day={publishedDate.day}
				slug={post.slug}
			/>
		</div>
		<div class="w-full md:w-3/5">
			<h2
				class="text-center mb-2 text-4xl text-wrap-balance auto-phrase"
				transition:name={'title-' + post.slug}
			>
				{post.title}
			</h2>
			<p class="text-center my-2 text-orange text-lg md:hidden block">
				{publishedDate.year}年{publishedDate.month}月{publishedDate.day}日
			</p>
			<p class="text-right">{post.reading_time} 分くらいで読めます！</p>
		</div>
		<div class="w-full md:w-1/5 hidden md:block pl-4"></div>
	</div>
	<div class="mb-4 mt-4 p-2 m-2">
		<TagList tags={post.tags?.map(tag => ({ name: tag.name || '', slug: tag.slug || '', visibility: tag.visibility || 'public' })) || []} />
	</div>
	<div class="px-4 mb-4 mx-auto" style="max-width: var(--article-max-width)">
		<EmojiReaction slug={post.slug} client:load />
	</div>
	<!-- 基本的にWordPress記事では目次生成の正規表現でマッチしないが、WordPressから移行した記事を一度Ghostで保存すると目次生成が可能になってしまい、spanタグの付いたぶっ壊れ目次が生まれるので防ぐ -->
	{
		isWpArticle ? (
			''
		) : (
			<div class="flex justify-center" id="toc-inline-wrapper">
				<TOC tocList={tocList} />
			</div>
		)
	}
	{}
	<article class="blog-content" set:html={post.html} />
	{}
	<!-- PC用スクロール追従サイドバー目次（xl以上で表示） -->
	{
		!isWpArticle && tocList.length > 0 && (
			<div
				id="toc-sidebar"
				class="hidden xl:block fixed z-10 top-24 max-h-[calc(100vh-7rem)] overflow-y-auto opacity-0 pointer-events-none transition-opacity duration-300"
				style="right: 2rem; width: calc((100vw - var(--article-max-width)) / 2 - 4rem)"
			>
				<TOC tocList={tocList} extraClass="ghost-toc-sidebar" />
			</div>
		)
	}

	<script>
		const inlineToc = document.getElementById("toc-inline-wrapper");
		const sidebarToc = document.getElementById("toc-sidebar");

		if (inlineToc && sidebarToc) {
			const showSidebar = () => {
				sidebarToc.classList.remove("opacity-0", "pointer-events-none");
				sidebarToc.classList.add("opacity-100");
			};
			const hideSidebar = () => {
				sidebarToc.classList.remove("opacity-100");
				sidebarToc.classList.add("opacity-0", "pointer-events-none");
			};

			const tocObserver = new IntersectionObserver((entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						// インライン目次が画面内に見えている → サイドバーを隠す
						hideSidebar();
					} else {
						// インライン目次が画面外へ
						// top < 0 = スクロールで上に消えた → サイドバーを表示
						// top > 0 = まだ画面下にある（未スクロール） → サイドバーを隠す
						if (entry.boundingClientRect.top < 0) {
							showSidebar();
						} else {
							hideSidebar();
						}
					}
				}
			});

			tocObserver.observe(inlineToc);

			// 現在位置のハイライト
			const articleHeadings = Array.from(
				document.querySelectorAll("article.blog-content [id]"),
			);
			const sidebarLinks = Array.from(
				sidebarToc.querySelectorAll("a[href^='#']"),
			);

			const setActive = (id: string) => {
				for (const link of sidebarLinks) {
					const isActive = link.getAttribute("href") === `#${id}`;
					(link as HTMLElement).style.fontWeight = isActive ? "bold" : "";
					(link as HTMLElement).style.color = isActive ? "var(--orange)" : "";
				}
			};

			const updateActive = () => {
				// スクロール位置より上にある見出しのうち最後のものをアクティブに
				let current = "";
				for (const heading of articleHeadings) {
					if (heading.getBoundingClientRect().top <= 80) {
						current = heading.id;
					}
				}
				setActive(current);
			};

			window.addEventListener("scroll", updateActive, { passive: true });
			updateActive();

			// サイドバーリンクをスムーズスクロールに
			for (const link of sidebarLinks) {
				link.addEventListener("click", (e) => {
					e.preventDefault();
					const href = link.getAttribute("href");
					if (!href) return;
					const id = href.slice(1);
					const target =
						document.getElementById(id) ||
						document.getElementById(decodeURIComponent(id));
					target?.scrollIntoView({ behavior: "smooth" });
				});
			}
		}
	</script>
</ArticleLayout>
