---
import PageHead from "~/components/atom/section/PageHead.astro";
import ArticleCell from "~/components/molecule/articleArchive/ArticleCell.astro";
import ArticleCellGrid from "~/components/molecule/articleArchive/ArticleCellGrid.astro";
import TagWall from "~/components/organism/tag/TagWall.astro";
import ArchiveLayout from "~/layouts/extends/ArchiveLayout.astro";
import { ghostApiWithRetry } from "~/libs/ghostClient";
import { buildFixedOgpMeta } from "~/libs/helper/ogpMeta";
import { isSlug } from "~/libs/validation/isSlug";
import type { HeadMetaType } from "~/types/HeadMetaType";

const tagSlug = Astro.params.tag;
if (!isSlug(tagSlug)) {
  return new Response(null, { status: 404 });
}

const posts =
  (await ghostApiWithRetry.posts.browse(
    {
      filter: `tag:${tagSlug}`,
      limit: 100,
      order: "published_at DESC",
      include: "tags",
    },
    3,
    Astro.request,
  )) || [];

const tag = await ghostApiWithRetry.tags.read(
  {
    slug: tagSlug,
  },
  3,
  Astro.request,
);

if (!tag) {
  return new Response(null, { status: 404 });
}

const headMeta: HeadMetaType = {
  title: `${tag.name}タグの記事一覧`,
  slug: `/tag/${tagSlug}`,
  description:
    tag.description ?? `うすゆきブログの${tag.name}タグの記事一覧です。`,
  ...buildFixedOgpMeta(),
};
---

<ArchiveLayout {...headMeta}>
	<PageHead en={tag.name ?? tagSlug} jp="タグの記事一覧" count={posts.length} />
	{
		tag.description && (
			<div class="tag-description">
				<div class="container">
					<p>{tag.description}</p>
				</div>
			</div>
		)
	}
	<section class="tag-list-section" aria-label={`${tag.name}タグの記事一覧`}>
		<div class="container">
			{
				posts.length > 0 ? (
					<ArticleCellGrid variant="list" class="tag-grid">
						{posts.map((article, index) => (
							<ArticleCell
								article={article}
								headingLevel="h2"
								eager={index === 0}
								transition={true}
							/>
						))}
					</ArticleCellGrid>
				) : (
					<p class="empty-message">このタグの記事はありません！</p>
				)
			}
		</div>
	</section>
	<TagWall sectionId="tags" />
</ArchiveLayout>

<style>
	.tag-description {
		border-bottom: 1px solid var(--color-border-light);
	}
	.tag-description p {
		padding: 16px 0;
		font-size: 0.9rem;
		color: var(--color-muted-dark);
	}
	.tag-list-section {
		padding-bottom: 72px;
	}
	.tag-list-section :global(.tag-grid) {
		margin-top: 48px;
	}
	.empty-message {
		text-align: center;
		font-size: 1.1rem;
		padding: 72px 0 24px;
	}
</style>
