---
import PageHead from "~/components/atom/section/PageHead.astro";
import { SITE_URL } from "~/consts";
import PageLayout from "~/layouts/extends/PageLayout.astro";
import { ghostApiWithRetry } from "~/libs/ghostClient";
import { thumbGradient } from "~/libs/helper/articleCell";
import { formatDotDate } from "~/libs/helper/formatDotDate";
import { optimizeGhostImageUrl } from "~/libs/helper/optimizeGhostImages";
import { getAllSlugReactions } from "~/libs/reactionClient";
import type { HeadMetaType } from "~/types/HeadMetaType";
import type { ArticleArchiveType } from "~/types/ArticleArchiveType";
import astroLogger from "~/libs/astroLogger";

const headMeta: HeadMetaType = {
  title: "リアクションが多い記事",
  slug: "/reactions",
  description: "リアクション数の多い記事のランキングです。",
  ogImage: `${SITE_URL}/images/ogp/ogp.png`,
};

let ranked: {
  slug: string;
  total: number;
  reactions: { emoji: string; count: number }[];
  post: ArticleArchiveType | null;
}[] = [];

try {
  const slugReactions = await getAllSlugReactions();

  // Ghost から記事情報をまとめて取得
  const slugs = slugReactions.map((r) => r.slug);
  const posts =
    slugs.length > 0
      ? ((await ghostApiWithRetry.posts.browse(
          {
            filter: `slug:[${slugs.join(",")}]`,
            fields: "slug,title,feature_image,published_at",
            limit: slugs.length,
          },
          3,
          Astro.request,
        )) ?? [])
      : [];

  const postMap = new Map(posts.map((p) => [p.slug, p]));

  ranked = slugReactions
    .map((sr) => ({ ...sr, post: postMap.get(sr.slug) ?? null }))
    .filter((sr) => sr.post !== null);
} catch (e) {
  astroLogger.componentError(
    "reactions",
    e instanceof Error ? e : new Error(String(e)),
  );
}
---

<PageLayout {...headMeta}>
	<PageHead en="Reactions" jp="リアクションが多い記事" count={ranked.length} />

	<section class="ranking-section" aria-label="リアクションランキング">
		<div class="container">
			<p class="ranking-note">リアクション数が多い順に並んでいます(ちょっとラグあり)</p>
			{
				ranked.length === 0 ? (
					<p class="empty-message">まだリアクションがありません</p>
				) : (
					<ol class="ranking-list">
						{ranked.map((item, index) => (
							<li>
								<a class="ranking-row" href={`/${item.slug}`}>
									<span class="ranking-no">{String(index + 1).padStart(2, "0")}</span>
									<span class="ranking-thumb">
										{item.post?.feature_image ? (
											<img
												src={optimizeGhostImageUrl(item.post.feature_image, {
													width: 300,
													height: 300,
												})}
												alt=""
												width={96}
												height={96}
												loading="lazy"
											/>
										) : (
											<span
												class="thumb-placeholder"
												style={`background: ${thumbGradient(item.slug)}`}
												aria-hidden="true"
											/>
										)}
									</span>
									<span class="ranking-body">
										<span class="ranking-date">
											{item.post?.published_at ? formatDotDate(item.post.published_at) : ""}
										</span>
										<h2 class="ranking-title">{item.post?.title}</h2>
										<span class="ranking-emojis">
											{item.reactions.map((r) => (
												<span class="emoji-chip">
													{r.emoji} <span class="emoji-count">{r.count}</span>
												</span>
											))}
										</span>
									</span>
									<span class="ranking-total">
										<strong>{item.total}</strong>
										<span>REACTIONS</span>
									</span>
								</a>
							</li>
						))}
					</ol>
				)
			}
		</div>
	</section>
</PageLayout>

<style>
	.ranking-section {
		padding-bottom: 96px;
	}
	.ranking-note {
		padding: 16px 0 32px;
		font-size: 0.85rem;
		color: var(--color-muted);
	}
	.empty-message {
		text-align: center;
		font-size: 1.1rem;
		padding: 72px 0;
	}
	.ranking-list {
		list-style: none;
		border-top: var(--bw) solid var(--color-ink);
	}
	.ranking-row {
		display: grid;
		grid-template-columns: 90px 96px 1fr auto;
		align-items: center;
		gap: 20px;
		border-bottom: var(--bw) solid var(--color-ink);
		padding: 18px 8px;
		transition: background 0.15s;
	}
	.ranking-row:hover {
		background: var(--color-gray);
	}
	.ranking-no {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: 2rem;
		line-height: 1;
	}
	.ranking-thumb {
		width: 96px;
		aspect-ratio: 1;
		border: var(--bw) solid var(--color-ink);
		overflow: hidden;
		display: block;
	}
	.ranking-thumb img,
	.thumb-placeholder {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.ranking-body {
		min-width: 0;
	}
	.ranking-date {
		font-family: var(--font-en);
		font-weight: 700;
		font-size: 0.7rem;
		letter-spacing: 0.18em;
		color: var(--color-muted);
	}
	.ranking-title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.6;
	}
	.ranking-row:hover .ranking-title {
		text-decoration: underline;
		text-underline-offset: 5px;
		text-decoration-thickness: 2px;
	}
	.ranking-emojis {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 6px;
	}
	.emoji-chip {
		font-size: 0.8rem;
		background: var(--color-gray);
		border: 1px solid var(--color-border-light);
		padding: 1px 8px;
	}
	.emoji-count {
		color: var(--color-muted);
	}
	.ranking-total {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding-right: 8px;
	}
	.ranking-total strong {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: 1.4rem;
		line-height: 1;
	}
	.ranking-total span {
		font-family: var(--font-en);
		font-size: 0.6rem;
		letter-spacing: 0.18em;
		color: var(--color-muted);
	}
	@media (max-width: 640px) {
		.ranking-row {
			grid-template-columns: 56px 1fr auto;
		}
		.ranking-thumb {
			display: none;
		}
		.ranking-no {
			font-size: 1.5rem;
		}
	}
</style>
