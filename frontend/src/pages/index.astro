---
import HeroSection from "~/components/organism/article/HeroSection.astro";
import LatestGrid from "~/components/organism/article/LatestGrid.astro";
import PickupSection from "~/components/organism/article/PickupSection.astro";
import TagWall from "~/components/organism/tag/TagWall.astro";
import {
  DEFAULT_OGP_IMAGE_HEIGHT,
  DEFAULT_OGP_IMAGE_WIDTH,
  SITE_URL,
} from "~/consts";
import { getLatestArticles } from "~/libs/articleAggregator";
import IndexLayout from "~/layouts/extends/IndexLayout.astro";
import type { HeadMetaType } from "~/types/HeadMetaType";
import astroLogger from "~/libs/astroLogger";

const headMeta: HeadMetaType = {
  title: "とっぷ",
  slug: "",
  description: "「急須で入れたようななにか」のトップページです",
  ogImage: `${SITE_URL}/images/ogp/ogp.png`,
  ogImageWidth: DEFAULT_OGP_IMAGE_WIDTH,
  ogImageHeight: DEFAULT_OGP_IMAGE_HEIGHT,
};

// Heroに1件、Latestグリッドに残り9件を使う(feature 2x2 + 8セルで4列×3行が埋まる)
const latestArticles = await getLatestArticles({
  limit: 10,
  includeExternal: true,
});
const heroArticle = latestArticles[0];
const gridArticles = latestArticles.slice(1);

astroLogger.requestLog(Astro.request, { status: 200 });
---

<IndexLayout {...headMeta}>
	{heroArticle && <HeroSection article={heroArticle} />}
	{gridArticles.length > 0 && <LatestGrid articles={gridArticles} />}
	<PickupSection />
	<TagWall sectionId="tags" />
</IndexLayout>
