---
interface Props {
  placeholder?: string;
  className?: string;
}

const { placeholder = "検索...", className = "" } = Astro.props;
---

<form
	class={`flex w-full items-stretch border border-ink ${className}`}
	action="https://www.google.com/search"
	method="get"
	target="_blank"
	role="search"
>
	<input type="hidden" name="sitesearch" value="blog.usuyuki.net" />
	<input
		type="text"
		name="q"
		placeholder={placeholder}
		class="min-w-0 flex-1 bg-paper px-3 py-1.5 text-sm text-ink placeholder:text-[#999] outline-none"
		required
	/>
	<button
		type="submit"
		class="shrink-0 bg-ink px-3 font-en text-xs font-bold tracking-[0.18em] text-paper transition-colors duration-150 hover:bg-orange"
	>
		SEARCH
	</button>
</form>
