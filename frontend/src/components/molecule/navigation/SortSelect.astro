---
import type { SortOrder } from "~/libs/helper/archiveQuery";

// 一覧ページの並び順セレクト(GETフォーム。JSありなら変更時に自動送信)
interface Props {
  currentYear?: number;
  sort: SortOrder;
}
const { currentYear, sort } = Astro.props;
---

<form class="sort-select" method="get" action="/archive">
	{currentYear !== undefined && <input type="hidden" name="year" value={String(currentYear)} />}
	<label>
		SORT
		<select name="sort" aria-label="並び順" onchange="this.form.submit()">
			<option value="newest" selected={sort === "newest"}>NEWEST</option>
			<option value="oldest" selected={sort === "oldest"}>OLDEST</option>
		</select>
	</label>
	<noscript>
		<button type="submit">OK</button>
	</noscript>
</form>

<style>
	.sort-select {
		display: flex;
		align-items: center;
		padding: 0 4px 0 20px;
		border-left: 1px solid var(--color-border-light);
		font-family: var(--font-en);
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		color: var(--color-muted);
	}
	.sort-select label {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.sort-select select {
		font-family: var(--font-en);
		font-weight: 700;
		font-size: 0.8rem;
		border: none;
		background: none;
		padding: 14px 8px;
		cursor: pointer;
		color: var(--color-ink);
	}
	.sort-select noscript button {
		font-family: var(--font-en);
		font-weight: 700;
		font-size: 0.72rem;
		border: 1px solid var(--color-ink);
		background: none;
		padding: 4px 10px;
		cursor: pointer;
	}
</style>
