---
import { buildArchiveUrl, type SortOrder } from "~/libs/helper/archiveQuery";

// 一覧ページの年別タブ(ALL + 記事が存在する年)
interface Props {
  years: number[];
  currentYear?: number;
  sort: SortOrder;
}
const { years, currentYear, sort } = Astro.props;
---

<nav class="year-tabs" aria-label="年別フィルター">
	<a href={buildArchiveUrl({ sort })} aria-current={currentYear === undefined ? "page" : undefined}>
		ALL
	</a>
	{
		years.map((year) => (
			<a
				href={buildArchiveUrl({ year, sort })}
				aria-current={currentYear === year ? "page" : undefined}
			>
				{year}
			</a>
		))
	}
</nav>

<style>
	.year-tabs {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(64px, 1fr));
		flex: 1 1 320px;
		width: 100%;
		min-width: 280px;
		border-left: var(--bw) solid var(--color-ink);
	}
	.year-tabs a {
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-en);
		font-weight: 700;
		font-size: 0.8rem;
		letter-spacing: 0.14em;
		padding: 14px 12px;
		white-space: nowrap;
		border-right: var(--bw) solid var(--color-ink);
		border-bottom: var(--bw) solid var(--color-ink);
		transition:
			background 0.15s,
			color 0.15s;
	}
	.year-tabs a:hover {
		background: var(--color-gray);
	}
	.year-tabs a[aria-current] {
		background: var(--color-ink);
		color: var(--color-paper);
	}
</style>
