---
import { Image } from "astro:assets";
import { optimizeGhostImageUrl } from "~/libs/helper/optimizeGhostImages";
import type { ArticleArchiveType } from "~/types/ArticleArchiveType";

interface Props {
  post: ArticleArchiveType;
  index: number;
  contextPrefix?: string;
}
const { post, index, contextPrefix = "" } = Astro.props;
---

<div class="w-1/2 md:w-1/3 lg:w-1/4 xl:w-1/5 mb-12">
	<a
		class="hover:shadow-xl hover:-translate-y-1 p-2 block rounded-xl h-full duration-300"
		href={post.isExternal ? post.externalUrl : `/${post.slug}`}
		target={post.isExternal ? "_blank" : "_self"}
		rel={post.isExternal ? "noopener noreferrer" : undefined}
	>
		<div class="flex justify-center items-center flex-col">
			<slot />
			<div class="overflow-hidden rounded-md">
				{post.feature_image ? (
					<Image
						src={optimizeGhostImageUrl(post.feature_image, { width: 480, height: 480 })}
						width={480}
						height={480}
						format="webp"
						quality={80}
						class="object-cover w-40 h-40 rounded-md transition-transform duration-300 hover:scale-105"
						alt="記事サムネイル"
						transition:name={'image-' + contextPrefix + post.slug}
						loading={index === 0 ? "eager" : "lazy"}
						fetchpriority={index === 0 ? "high" : "auto"}
						sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, (max-width: 1280px) 25vw, 20vw"
					/>
				) : post.isExternal && post.source ? (
					post.sourceColor && post.sourceColor.startsWith('#') ? (
						<div
							class="w-40 h-40 rounded-md flex items-center justify-center font-bold text-white text-xl shadow-lg"
							style={`background-color: ${post.sourceColor}`}
						>
							<span>{post.source.slice(0, 5) || 'Blog'}</span>
						</div>
					) : (
						<div
							class={`w-40 h-40 rounded-md flex items-center justify-center font-bold text-white text-xl shadow-lg ${post.sourceColor || 'bg-gray-600'}`}
						>
							<span>{post.source.slice(0, 5) || 'Blog'}</span>
						</div>
					)
				) : (
					<div class="aspect-square h-40 object-cover bg-gray-200 rounded-md" />
				)}
			</div>
			<h3
				class="text-xl text-black pt-2 text-wrap-balance text-center auto-phrase"
				transition:name={'title-' + contextPrefix + post.slug}
			>
				{post.title}
			</h3>
			{post.source && (
				<div class="text-sm text-gray-500 mt-1">{post.source}</div>
			)}
		</div>
	</a>
</div>
