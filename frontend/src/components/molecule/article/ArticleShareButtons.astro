---
import {
  buildTwitterShareUrl,
  buildHatenaBookmarkUrl,
  buildMisskeyShareUrl,
} from "~/libs/helper/shareUrl";

interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;

const twitterUrl = buildTwitterShareUrl(url, title);
const hatenaUrl = buildHatenaBookmarkUrl(url);
const misskeyUrl = buildMisskeyShareUrl(url, title);
---

<div class="my-6 flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-center">
	<div class="flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap">
		<a
			href={twitterUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="flex w-full items-center justify-center gap-2 rounded-xl bg-black px-4 py-2 text-white hover:opacity-80 duration-300 sm:w-auto"
		>
			<img
				src="/images/icon/x-logo.svg"
				alt="X"
				width="20"
				height="20"
				class="w-5 h-5 invert"
			/>
			<span>X でシェア</span>
		</a>
		<a
			href={misskeyUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="flex w-full items-center justify-center gap-2 rounded-xl bg-black px-4 py-2 text-white hover:opacity-80 duration-300 sm:w-auto"
		>
			<img
				src="/images/icon/misskey-logo.png"
				alt="Misskey"
				width="20"
				height="20"
				class="w-5 h-5"
			/>
			<span>Misskey でシェア</span>
		</a>
		<!-- 公式はてなブックマークボタン（ブックマーク数付き） -->
		<div class="flex items-center justify-center py-2">
			<a
				href={hatenaUrl}
				class="hatena-bookmark-button"
				data-hatena-bookmark-layout="basic-label-counter"
				data-hatena-bookmark-lang="ja"
				title="このエントリーをはてなブックマークに追加"
				target="_blank"
				rel="noopener noreferrer"
			>
				<img
					src="https://b.st-hatena.com/images/v4/public/entry-button/button-only@2x.png"
					alt="このエントリーをはてなブックマークに追加"
					width="20"
					height="20"
					style="border: none;"
				/>
			</a>
			<script is:inline src="https://b.st-hatena.com/js/bookmark_button.js" async></script>
		</div>
		<a
			href="https://feedly.com/i/subscription/feed%2Fhttps%3A%2F%2Fblog.usuyuki.net%2Frss.xml"
			target="_blank"
			rel="noopener noreferrer"
			class="flex items-center justify-center px-4 py-2 hover:opacity-80 duration-300"
		>
			<img
				src="https://s1.feedly.com/legacy/feedly-follow-circle-flat-black_2x.png"
				alt="follow us in feedly"
				width="28"
				height="28"
			/>
		</a>
	</div>
	<button
		data-back-to-top
		class="flex flex-col items-center gap-1 cursor-pointer mt-8 sm:mt-0 sm:ml-16"
		aria-label="トップへ戻る"
	>
		<span class="flex items-center justify-center rounded-full bg-green w-10 h-10 text-white hover:bg-blue duration-300">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
				<path fill-rule="evenodd" d="M11.47 2.47a.75.75 0 0 1 1.06 0l7.5 7.5a.75.75 0 1 1-1.06 1.06l-6.22-6.22V21a.75.75 0 0 1-1.5 0V4.81l-6.22 6.22a.75.75 0 1 1-1.06-1.06l7.5-7.5Z" clip-rule="evenodd" />
			</svg>
		</span>
		<span class="text-xs">トップに戻る</span>
	</button>
</div>

<script>
	document
		.querySelector("[data-back-to-top]")
		?.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});
</script>
