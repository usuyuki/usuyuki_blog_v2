---
import type { ArticleArchiveType } from "~/types/ArticleArchiveType";

// 前後記事ナビ(prev = 1つ古い記事、next = 1つ新しい記事)
interface Props {
  prev: ArticleArchiveType | null;
  next: ArticleArchiveType | null;
}
const { prev, next } = Astro.props;
---

{
	(prev || next) && (
		<nav class="prev-next" aria-label="前後の記事">
			{prev ? (
				<a class="prev" href={`/${prev.slug}`}>
					<span class="pn-label">← PREV</span>
					<span class="pn-title">{prev.title}</span>
				</a>
			) : (
				<span class="pn-empty" />
			)}
			{next ? (
				<a class="next" href={`/${next.slug}`}>
					<span class="pn-label">NEXT →</span>
					<span class="pn-title">{next.title}</span>
				</a>
			) : (
				<span class="pn-empty next" />
			)}
		</nav>
	)
}

<style>
	.prev-next {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-bottom: var(--bw) solid var(--color-ink);
	}
	.prev-next a {
		padding: 28px 32px;
		display: flex;
		flex-direction: column;
		gap: 6px;
		transition: background 0.15s;
	}
	.prev-next a:hover {
		background: var(--color-gray);
	}
	.prev-next a:hover .pn-title {
		text-decoration: underline;
		text-underline-offset: 5px;
		text-decoration-thickness: 2px;
	}
	.prev-next .next {
		border-left: var(--bw) solid var(--color-ink);
		text-align: right;
		align-items: flex-end;
	}
	.pn-label {
		font-family: var(--font-en);
		font-weight: 700;
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		color: #888;
	}
	.pn-title {
		font-weight: 700;
		font-size: 0.92rem;
		line-height: 1.6;
	}
	@media (max-width: 640px) {
		.prev-next {
			grid-template-columns: 1fr;
		}
		.prev-next .next {
			border-left: none;
			border-top: var(--bw) solid var(--color-ink);
		}
		.pn-empty {
			display: none;
		}
	}
</style>
