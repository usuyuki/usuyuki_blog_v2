---
import { thumbGradient } from "~/libs/helper/articleCell";
import { optimizeGhostImageUrl } from "~/libs/helper/optimizeGhostImages";
import type { ArticleArchiveType } from "~/types/ArticleArchiveType";

// 前後記事ナビ(prev = 1つ古い記事、next = 1つ新しい記事)
interface Props {
  prev: ArticleArchiveType | null;
  next: ArticleArchiveType | null;
}
const { prev, next } = Astro.props;

// サムネイルはグレースケール背景として敷く。画像がなければプレースホルダーのグラデーション
const thumbStyle = (article: ArticleArchiveType) =>
  article.feature_image
    ? `--pn-thumb: url(${optimizeGhostImageUrl(article.feature_image, { width: 600, height: 338 })})`
    : `--pn-thumb: ${thumbGradient(article.slug)}`;
---

{
	(prev || next) && (
		<nav class="prev-next" aria-label="前後の記事">
			{prev ? (
				<div class="pn-wrapper prev-wrapper">
					<a class="prev" href={`/${prev.slug}`} style={thumbStyle(prev)}>
						<span class="pn-body">
							<span class="pn-label">← PREV</span>
							<span class="pn-title">{prev.title}</span>
						</span>
					</a>
				</div>
			) : (
				<span class="pn-empty" />
			)}
			{next ? (
				<div class="pn-wrapper next-wrapper">
					<a class="next" href={`/${next.slug}`} style={thumbStyle(next)}>
						<span class="pn-body">
							<span class="pn-label">NEXT →</span>
							<span class="pn-title">{next.title}</span>
						</span>
					</a>
				</div>
			) : (
				<span class="pn-empty next" />
			)}
		</nav>
	)
}

<style>
	.prev-next {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-bottom: var(--bw) solid var(--color-ink);
	}
	.prev-next a {
		position: relative;
		padding: 28px 32px;
		display: flex;
		overflow: hidden;
	}
	.prev-next a::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image: var(--pn-thumb);
		background-size: cover;
		background-position: center;
		filter: grayscale(1);
		transition: filter 0.15s;
	}
	.prev-next a:hover::before {
		filter: grayscale(0);
	}
	.prev-next a::after {
		content: "";
		position: absolute;
		inset: 0;
		background: rgb(255 255 255 / 78%);
		transition: background 0.15s;
	}
	.prev-next a:hover::after {
		background: rgb(255 255 255 / 88%);
	}
	.prev-next a:hover .pn-title {
		text-decoration: underline;
		text-underline-offset: 5px;
		text-decoration-thickness: 2px;
	}
	.prev-next .pn-wrapper.next-wrapper {
		border-left: var(--bw) solid var(--color-ink);
	}
	.prev-next .next {
		text-align: right;
		justify-content: flex-end;
	}
	.pn-wrapper {
		display: flex;
		flex-direction: column;
	}
	.pn-wrapper a {
		flex: 1;
	}
	.pn-body {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		gap: 6px;
		min-width: 0;
	}
	.pn-label {
		font-family: var(--font-en);
		font-weight: 700;
		font-size: 0.7rem;
		letter-spacing: 0.22em;
		color: #000;
		opacity: 0.6;
	}
	.pn-title {
		font-weight: 700;
		font-size: 0.92rem;
		line-height: 1.6;
		color: #000;
		overflow-wrap: anywhere;
		word-break: normal;
	}
	@media (max-width: 640px) {
		.prev-next {
			grid-template-columns: 1fr;
			overflow-x: hidden;
		}
		.prev-next a {
			padding: 24px 20px;
		}
		.prev-next .prev {
			justify-content: flex-start;
			padding-right: 15%;
			padding-left: 44px;
			margin-left: -24px;
			margin-right: 24px;
		}
		.prev-next .pn-wrapper.next-wrapper {
			border-left: none;
			border-top: var(--bw) solid var(--color-ink);
		}
		.prev-next .next {
			justify-content: flex-end;
			padding-left: 15%;
			padding-right: 44px;
			margin-left: 24px;
			margin-right: -24px;
		}
		.pn-empty {
			display: none;
		}
	}
</style>
